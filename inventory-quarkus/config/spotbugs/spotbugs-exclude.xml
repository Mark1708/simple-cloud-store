<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Classes with @Generated annotation -->
    <Match>
        <Annotation name="javax.annotation.Generated"/>
    </Match>
    <Match>
        <Annotation name="jakarta.annotation.Generated"/>
    </Match>

    <!-- Generated OpenAPI utilities (without @Generated annotation) -->
    <Match>
        <Source name="~ApiUtil\.java"/>
    </Match>

    <!-- Find Security Bugs: SLF4J parameterized logging is safe from CRLF injection -->
    <Match>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
    </Match>
</FindBugsFilter>
